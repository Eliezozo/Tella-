generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  TAILOR
  ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  RELANCE
  EXPIRED
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  phone         String?        @unique
  passwordHash  String?
  image         String?
  role          UserRole       @default(TAILOR)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tailorProfile TailorProfile?
  reviews       Review[]       @relation("ReviewAuthor")
  favorites     Favorite[]
  orders        Order[]        @relation("ClientOrders")
  messages      Message[]      @relation("UserMessages")
}

model TailorProfile {
  id              String         @id @default(cuid())
  userId          String         @unique
  handle          String         @unique
  atelierName     String
  city            String
  bio             String
  heroLabel       String
  whatsapp        String
  bannerUrl       String?
  avatarUrl       String?
  specialties     String[]
  responseRate    Int            @default(0)
  viewsCount      Int            @default(0)
  whatsappClicks  Int            @default(0)
  averageRating   Float          @default(0)
  reviewsCount    Int            @default(0)
  completedOrders Int            @default(0)
  isApproved      Boolean        @default(false)
  isPublished     Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolios      Portfolio[]
  posts           Post[]
  reviews         Review[]
  orders          Order[]
  favorites       Favorite[]
  subscription    Subscription?
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  posts     Post[]
}

model Post {
  id              String        @id @default(cuid())
  slug            String        @unique
  tailorProfileId String
  categoryId      String?
  title           String
  description     String        @default("")
  mediaUrl        String
  mediaType       String        @default("image")
  priceFrom       Int?
  turnaroundLabel String?
  likesCount      Int           @default(0)
  isPublished     Boolean       @default(true)
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  tailorProfile   TailorProfile @relation(fields: [tailorProfileId], references: [id], onDelete: Cascade)
  category        Category?     @relation(fields: [categoryId], references: [id])
}

model Portfolio {
  id              String        @id @default(cuid())
  tailorProfileId String
  title           String
  description     String?
  coverUrl        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  tailorProfile   TailorProfile @relation(fields: [tailorProfileId], references: [id], onDelete: Cascade)
}

model Review {
  id              String        @id @default(cuid())
  tailorProfileId String
  authorId        String
  rating          Int
  comment         String
  photoUrl        String?
  createdAt       DateTime      @default(now())
  tailorProfile   TailorProfile @relation(fields: [tailorProfileId], references: [id], onDelete: Cascade)
  author          User          @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
}

model Order {
  id              String        @id @default(cuid())
  tailorProfileId String
  clientId        String
  title           String
  status          String
  amount          Int?
  dueDate         DateTime?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  tailorProfile   TailorProfile @relation(fields: [tailorProfileId], references: [id], onDelete: Cascade)
  client          User          @relation("ClientOrders", fields: [clientId], references: [id], onDelete: Cascade)
}

model Message {
  id        String   @id @default(cuid())
  userId    String
  channel   String
  body      String
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation("UserMessages", fields: [userId], references: [id], onDelete: Cascade)
}

model Favorite {
  id              String        @id @default(cuid())
  userId          String
  tailorProfileId String
  createdAt       DateTime      @default(now())
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tailorProfile   TailorProfile @relation(fields: [tailorProfileId], references: [id], onDelete: Cascade)

  @@unique([userId, tailorProfileId])
}

model Subscription {
  id              String             @id @default(cuid())
  tailorProfileId String             @unique
  planKey         String
  status          SubscriptionStatus @default(ACTIVE)
  amount          Int
  renewsAt        DateTime?
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  tailorProfile   TailorProfile      @relation(fields: [tailorProfileId], references: [id], onDelete: Cascade)
}
